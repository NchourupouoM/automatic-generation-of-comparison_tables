# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `DATABASE_URL` is required; the rest have
# sensible defaults for local development.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (required). Must start with postgresql://
DATABASE_URL=postgresql://user:pass@localhost:5432/extractor

# Redis broker/result backend for Celery
REDIS_URL=redis://localhost:6379/0

# LLM provider: openai | anthropic | ollama | google
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o

# Provider credentials — set the one matching LLM_PROVIDER
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_API_KEY=your-google-api-key
# OLLAMA_BASE_URL=http://localhost:11434

# Optional API security. When set, mutating endpoints require the header
# `X-API-Key: <this value>`. Leave unset for an open API (local dev).
# API_KEY=change-me-to-a-long-random-string

# Optional pagination tuning for list endpoints
# DEFAULT_PAGE_SIZE=50
# MAX_PAGE_SIZE=200
